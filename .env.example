# Example .env for backend
# Copy this to .env and fill in values (do NOT commit your real .env to git)

# Your Gemini API key (keep secret)
GEMINI_API_KEY=your_gemini_api_key_here

# Base Gemini API URL (no trailing slash)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateMessage

# Optional: request timeout to Gemini in milliseconds
GEMINI_REQUEST_TIMEOUT_MS=30000

# Server port
PORT=5000
