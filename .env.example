# Example .env for backend
# Copy this to .env and fill in values (do NOT commit your real .env to git)

# Your GROQ API key (keep secret)
GROQ_API_KEY=your_groq_api_key_here

# Base Groq API URL (no trailing slash) - default used in code is https://api.groq.com/openai/v1
GROQ_API_URL=https://api.groq.com/openai/v1

# Optional: request timeout to Groq in milliseconds
GROQ_REQUEST_TIMEOUT_MS=30000

# Server port
PORT=5000
